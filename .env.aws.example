APP_URL=https://app.tu-dominio.com
WEB_PORT=80

# Recomendado: Amazon RDS PostgreSQL.
# Formato:
# postgresql://USUARIO:PASSWORD@ENDPOINT_RDS:5432/NOMBRE_DB?schema=public&sslmode=require
DATABASE_URL=postgresql://trajet:cambia_esta_clave_postgres_larga@tu-rds.xxxxxx.us-east-1.rds.amazonaws.com:5432/trajet?schema=public&sslmode=require

JWT_SECRET=cambia_este_jwt_secret_minimo_32_caracteres

TRAJET_ADMIN_EMAIL=admin@tu-dominio.com
TRAJET_ADMIN_PASSWORD=cambia_esta_clave_admin_larga

# SMTP real para bienvenida y verificacion de correo.
# Ejemplo AWS SES: SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_usuario_smtp
SMTP_PASS=tu_password_smtp
SMTP_FROM=TRAJET <no-reply@tu-dominio.com>

# Opcional: dominios extra separados por coma. Ejemplo:
# EXTRA_CORS_ORIGINS=,https://cliente1.tu-dominio.com,https://cliente2.tu-dominio.com
EXTRA_CORS_ORIGINS=

# Opcional: WhatsApp Cloud API de Meta.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
